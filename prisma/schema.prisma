generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?
  xp            Int       @default(0)
  bannerColor   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  progress     LessonProgress[]
  streak       DailyStreak?
  achievements Achievement[]
  dailyStages  DailyStage[]
  mastery      ConceptMastery[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Section = the big level bucket (Beginner, Elementary, etc.)
model Stage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  order       Int
  icon        String?
  createdAt   DateTime @default(now())

  units Unit[]
}

// Unit = a topic cluster within a section (e.g. "Perfect Intervals")
model Unit {
  id          String   @id @default(cuid())
  stageId     String
  slug        String   @unique
  title       String
  description String?
  order       Int
  createdAt   DateTime @default(now())

  stage   Stage    @relation(fields: [stageId], references: [id])
  lessons Lesson[]

  @@index([stageId, order])
}

model Lesson {
  id             String       @id @default(cuid())
  unitId         String
  slug           String       @unique
  title          String
  order          Int
  exerciseType   ExerciseType
  exerciseConfig Json
  passingScore   Int          @default(70)
  xpReward       Int          @default(10)
  createdAt      DateTime     @default(now())

  unit     Unit             @relation(fields: [unitId], references: [id])
  progress LessonProgress[]

  @@index([unitId, order])
}

enum ExerciseType {
  PITCH_MATCH
  SIGHT_READ_PIANO
  EAR_SINGLE
  EAR_MULTI
  INTERVAL_ID
  NOTE_VALUE_ID
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  score       Int
  passed      Boolean  @default(false)
  attempts    Int      @default(1)
  xpEarned    Int      @default(0)
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@index([userId, lessonId])
  @@index([userId, completedAt])
}

model DailyStreak {
  id               String    @id @default(cuid())
  userId           String    @unique
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id         String          @id @default(cuid())
  userId     String
  type       AchievementType
  unlockedAt DateTime        @default(now())
  metadata   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

enum AchievementType {
  FIRST_LESSON
  PERFECT_SCORE
  STREAK_7
  STREAK_30
  STAGE_COMPLETE
  ALL_STAGES
}

// Per-user, per-concept mastery state for the spaced-repetition / adaptive engine.
// conceptId follows the slot-generator scheme (e.g. "ear-note:C4", "ear-interval:Perfect 4th").
model ConceptMastery {
  id                  String   @id @default(cuid())
  userId              String
  conceptId           String
  timesSeen           Int      @default(0)
  timesCorrect        Int      @default(0)
  currentStreak       Int      @default(0)
  lastSeenAt          DateTime @default(now())
  lastSeenLessonSlug  String?
  // Number of lessons-from-now this concept becomes due for review (SM-2-ish).
  // Lower = sooner. Stored as Int so the slot generator can compare against a
  // monotonic lesson counter without DateTime math.
  reviewIntervalDays  Float    @default(1)
  nextReviewAt        DateTime @default(now())
  // Rolling accuracy 0..1; weighted toward recent answers.
  masteryScore        Float    @default(0)
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conceptId])
  @@index([userId, nextReviewAt])
  @@index([userId, masteryScore])
}

model DailyStage {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime
  difficulty String
  exercises  Json
  completed  Boolean  @default(false)
  score      Int?
  xpEarned   Int      @default(0)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}
